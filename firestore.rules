rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function emailOf() {
      return request.auth.token.email;
    }
    // Mom, Dad, and the Dietician can author the meal plan and food list.
    // Family is read-only. UI separately gates Dietician away from the daily
    // logging actions (mark fed, photos, mood, reactions, growth, profile).
    function isWriter() {
      return isSignedIn() && (
        emailOf() == 'mom@daivik.app' ||
        emailOf() == 'dad@daivik.app' ||
        emailOf() == 'dietician@daivik.app'
      );
    }
    function isReader() {
      return isSignedIn() && (
        emailOf() == 'mom@daivik.app' ||
        emailOf() == 'dad@daivik.app' ||
        emailOf() == 'dietician@daivik.app' ||
        emailOf() == 'family@daivik.app'
      );
    }

    match /app/state {
      allow read:  if isReader();
      allow write: if isWriter();
    }

    // FCM push tokens — each signed-in user can update their own role's token list.
    // The server-side /api/notify route uses Admin SDK which bypasses these rules.
    match /fcm/tokens {
      allow read:  if isReader();
      allow write: if isReader(); // any signed-in role can register/update their token
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
